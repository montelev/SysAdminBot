# .streamlit/secrets.toml is used by Streamlit Community Cloud.
# For local development, use a .env file instead (see .env.example).
#
# To use this file locally:
#   1. Create the folder:  mkdir .streamlit
#   2. Copy this file:     copy secrets.toml.example .streamlit\secrets.toml
#   3. Fill in your key below.
#
# NEVER commit .streamlit/secrets.toml to git.

GEMINI_API_KEY = "your_gemini_api_key_here"
